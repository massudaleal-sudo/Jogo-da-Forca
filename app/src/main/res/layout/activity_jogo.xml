<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.tools.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".JogoActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvInfoJogador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_jogador"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true" />

        <TextView
            android:id="@+id/tvCronometro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_tempo"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_alignParentEnd="true" />
    </RelativeLayout>

    <ImageView
        android:id="@+id/ivForca"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="fitCenter"
        android:src="@android:drawable/ic_menu_report_image"
        android:contentDescription="@string/desc_imagem_forca"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvPalavraOculta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="_ _ _ _ _"
        android:textSize="32sp"
        android:gravity="center"
        android:letterSpacing="0.2"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvPontuacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_pontuacao"
        android:textSize="14sp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:id="@+id/layoutTeclado"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnReiniciar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_reiniciar"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSair"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_sair"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>